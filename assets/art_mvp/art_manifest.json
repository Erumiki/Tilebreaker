    "brief": "design/art-mvp-brief.md",
    "root": "assets/art_mvp",
    "format": "png",
    "naming": {
        "files": "lowercase_underscore_png",
        "ids": "lowercase_underscore",
        "states": "lowercase_underscore"
    },
    "gameplayLocks": {
        "tileTopologySources": [
            "assets/tiles_v2/tile_manifest.json",
            "configs/game.json:tileBattle.specialTiles"
        ],
        "note": "Art may replace PNG pixels, but must not change tile matrix, edges, color, pattern, wildcard rules or scoring semantics."
    },
    "states": {
        "screen_background": ["menu", "battle_intro", "battle", "shop", "result"],
        "level_backdrop": ["battle_01", "battle_02", "battle_03", "battle_04", "battle_05"],
        "board_cell": ["empty", "hover", "valid", "invalid", "scored"],
        "tile_state": ["unclosed", "closed", "scored_fade"],
        "slot": ["empty", "hover", "selected", "filled"],
        "card_frame": ["common", "uncommon", "rare", "disabled", "bought"],
        "button": ["default", "hover", "pressed", "disabled"],
        "monster_portrait": ["battle_01", "battle_02", "battle_03", "battle_04", "battle_05"],
        "monster_icon": ["battle_01", "battle_02", "battle_03", "battle_04", "battle_05"],
        "icon": ["heart_full", "heart_empty", "heart_lost", "gold", "strike", "deck", "discard", "hold", "multiplier", "submit", "lock"],
        "overlay": ["capture_red", "capture_blue", "valid_cell", "invalid_cell", "selected_tile", "hover_tile", "target_a", "target_b", "gate_start", "gate_end"],
